#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid "CRM"
msgstr "CRM"

#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid ""
"If lead is created for existing contact, schedule a call with their "
"salesperson."
msgstr ""
"ຖ້າຫາກຜູ້ມີໂອກາດຖືກສ້າງຂຶ້ນສຳລັບຜູ້ຕິດຕໍ່ທີ່ມີຢູ່ແລ້ວ, ໃຫ້ກຳນົດເວລານັດໝາຍໂທຫາພະນັກງານຂາຍຂອງພວກເຂົາ."

#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid "If not opened, priority = 0"
msgstr "ຖ້າບໍ່ໄດ້ເປີດເບິ່ງ, ຄວາມສຳຄັນ = 0"

#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid "If replied, assign 3 stars"
msgstr "ຖ້າມີການຕອບກັບ, ໃຫ້ກຳນົດ 3 ດາວ"

#. module: marketing_automation_crm
#: model:ir.model,name:marketing_automation_crm.model_marketing_campaign
msgid "Marketing Campaign"
msgstr "ແຄມເປນການຕະຫຼາດ"

#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid "Next activity: Call"
msgstr "ກິດຈະກຳຕໍ່ໄປ: ໂທຫາ"

#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid "Not Opened, Low Priority"
msgstr "ບໍ່ໄດ້ເປີດເບິ່ງ, ຄວາມສຳຄັນຕ່ຳ"

#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid "Prioritize Hot Leads"
msgstr "ຈັດລຳດັບຄວາມສຳຄັນໃຫ້ຜູ້ມີໂອກາດທີ່ມາແຮງ"

#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid "Replied High Priority"
msgstr "ຕອບກັບແລ້ວ ຄວາມສຳຄັນສູງ"

#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid "Schedule Call"
msgstr "ກຳນົດເວລານັດໝາຍໂທ"

#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid "Schedule Calls"
msgstr "ກຳນົດເວລານັດໝາຍໂທ"

#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid "Send Email"
msgstr "ສົ່ງອີເມລ"

#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid ""
"Send an email to new leads and assign them a high priority if they open it."
msgstr ""
"ສົ່ງອີເມລຫາຜູ້ມີໂອກາດໃໝ່ ແລະ ກຳນົດຄວາມສຳຄັນສູງໃຫ້ພວກເຂົາ ຖ້າພວກເຂົາເປີດເບິ່ງອີເມລນັ້ນ."

#. module: marketing_automation_crm
#. odoo-python
#: code:addons/marketing_automation_crm/models/marketing_campaign.py:0
msgid "Send welcome Email"
msgstr "ສົ່ງອີເມລຕ້ອນຮັບ"
