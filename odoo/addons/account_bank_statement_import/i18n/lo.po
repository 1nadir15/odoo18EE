#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "%d transactions had already been imported and were ignored."
msgstr "%d ທຸລະກຳໄດ້ຖືກນຳເຂົ້າແລ້ວ ແລະ ຖືກລະເວັ້ນ."

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "1 transaction had already been imported and was ignored."
msgstr "1 ທຸລະກຳໄດ້ຖືກນຳເຂົ້າແລ້ວ ແລະ ຖືກລະເວັ້ນ."

#. module: account_bank_statement_import
#: model:ir.model.constraint,message:account_bank_statement_import.constraint_account_bank_statement_line_unique_import_id
msgid "A bank account transactions can be imported only once!"
msgstr "ທຸລະກຳບັນຊີທະນາຄານສາມາດນຳເຂົ້າໄດ້ພຽງຄັ້ງດຽວເທົ່ານັ້ນ!"

#. module: account_bank_statement_import
#: model:ir.model,name:account_bank_statement_import.model_account_bank_statement_line
msgid "Bank Statement Line"
msgstr "ລາຍການໃບແຈ້ງຍອດທະນາຄານ"

#. module: account_bank_statement_import
#: model:ir.model,name:account_bank_statement_import.model_account_setup_bank_manual_config
msgid "Bank setup manual config"
msgstr "ການຕັ້ງຄ່າທະນາຄານດ້ວຍຕົນເອງ"

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "Cannot find in which journal import this statement. Please manually select a journal."
msgstr ""
"ບໍ່ພົບວ່າຈະນຳເຂົ້າໃບແຈ້ງຍອດນີ້ໃສ່ໃນປຶ້ມບັນຊີໃດ. ກະລຸນາເລືອກປຶ້ມບັນຊີດ້ວຍຕົນເອງ."

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid ""
"Could not make sense of the given file.\n"
"Did you install the module to support this type of file?"
msgstr ""
"ບໍ່ສາມາດອ່ານໄຟລ໌ທີ່ໃຫ້ມາໄດ້.\n"
"ເຈົ້າໄດ້ຕິດຕັ້ງໂມດູນເພື່ອຮອງຮັບໄຟລ໌ປະເພດນີ້ແລ້ວຫຼືບໍ?"

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "Go to Apps"
msgstr "ໄປທີ່ແອັບ"

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "If it contains transactions for more than one account, it must be imported on each of them."
msgstr ""
"ຖ້າມັນມີທຸລະກຳຫຼາຍກວ່າໜຶ່ງບັນຊີ, ມັນຈະຕ້ອງຖືກນຳເຂົ້າໃນແຕ່ລະບັນຊີເຫຼົ່ານັ້ນ."

#. module: account_bank_statement_import
#: model:ir.model.fields,field_description:account_bank_statement_import.field_account_bank_statement_line__unique_import_id
msgid "Import ID"
msgstr "ໄອດີການນຳເຂົ້າ"

#. module: account_bank_statement_import
#. odoo-javascript
#: code:addons/account_bank_statement_import/static/src/account_bank_statement_import_model.js:0
msgid "Import Template for Bank Statements"
msgstr "ແບບຟອມນຳເຂົ້າສຳລັບໃບແຈ້ງຍອດທະນາຄານ"

#. module: account_bank_statement_import
#: model:ir.model,name:account_bank_statement_import.model_account_journal
msgid "Journal"
msgstr "ປຶ້ມບັນຊີປະຈຳວັນ"

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "Manual (or import %(import_formats)s)"
msgstr "ດ້ວຍຕົນເອງ (ຫຼື ນຳເຂົ້າ %(import_formats)s)"

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "No attachment was provided"
msgstr "ບໍ່ມີໄຟລ໌ຄັດຕິດ"

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "No currency found matching '%s'."
msgstr "ບໍ່ພົບສະກຸນເງິນທີ່ກົງກັບ '%s'."

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "The account of this statement (%s) is not the same as the journal (%s)."
msgstr "ບັນຊີຂອງໃບແຈ້ງຍອດນີ້ (%s) ບໍ່ກົງກັບປຶ້ມບັນຊີ (%s)."

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "The currency of the bank statement (%s) is not the same as the currency of the journal (%s)."
msgstr "ສະກຸນເງິນຂອງໃບແຈ້ງຍອດທະນາຄານ (%s) ບໍ່ກົງກັບສະກຸນເງິນຂອງປຶ້ມບັນຊີ (%s)."

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "The following files could not be imported:\n"
msgstr "ໄຟລ໌ຕໍ່ໄປນີ້ບໍ່ສາມາດນຳເຂົ້າໄດ້:\n"

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "This file doesn't contain any statement for account %s."
msgstr "ໄຟລ໌ນີ້ບໍ່ມີໃບແຈ້ງຍອດໃດໆສຳລັບບັນຊີ %s."

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "This file doesn't contain any transaction for account %s."
msgstr "ໄຟລ໌ນີ້ບໍ່ມີທຸລະກຳໃດໆສຳລັບບັນຊີ %s."

#. module: account_bank_statement_import
#: model_terms:ir.ui.view,arch_db:account_bank_statement_import.journal_dashboard_view_inherit
msgid "Transactions"
msgstr "ທຸລະກຳ"

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "View successfully imported statements"
msgstr "ເບິ່ງໃບແຈ້ງຍອດທີ່ນຳເຂົ້າສຳເລັດແລ້ວ"

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "You already have imported that file."
msgstr "ເຈົ້າໄດ້ນຳເຂົ້າໄຟລ໌ນັ້ນແລ້ວ."

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "You have to set a Default Account for the journal: %s"
msgstr "ເຈົ້າຕ້ອງກຳນົດບັນຊີເລີ່ມຕົ້ນໃຫ້ກັບປຶ້ມບັນຊີ: %s"

#. module: account_bank_statement_import
#. odoo-python
#: code:addons/account_bank_statement_import/models/account_journal.py:0
msgid "You uploaded an invalid or empty file."
msgstr "ເຈົ້າໄດ້ອັບໂຫຼດໄຟລ໌ທີ່ບໍ່ຖືກຕ້ອງ ຫຼື ໄຟລ໌ຫວ່າງເປົ່າ."

#. module: account_bank_statement_import
#: model_terms:ir.ui.view,arch_db:account_bank_statement_import.journal_dashboard_view_inherit
msgid "or"
msgstr "ຫຼື"
