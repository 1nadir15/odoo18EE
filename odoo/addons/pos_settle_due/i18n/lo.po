msgstr "ລາຍການສັ່ງຊື້ຫວ່າງເປົ່າ"

#. module: pos_settle_due
#. odoo-javascript
#: code:addons/pos_settle_due/static/src/overrides/components/partner_list/partner_line/partner_line.xml:0
msgid "Total due:"
msgstr "ຍອດຄ້າງຊຳລະທັງໝົດ:"

#. module: pos_settle_due
#. odoo-javascript
#: code:addons/pos_settle_due/static/src/overrides/components/payment_screen/payment_screen.js:0
msgid "Yes"
msgstr "ແມ່ນ"

#. module: pos_settle_due
#. odoo-javascript
#: code:addons/pos_settle_due/static/src/overrides/components/payment_screen/payment_screen.js:0
msgid "You can not deposit zero amount."
msgstr "ທ່ານບໍ່ສາມາດຝາກເງິນຈຳນວນສູນໄດ້."
