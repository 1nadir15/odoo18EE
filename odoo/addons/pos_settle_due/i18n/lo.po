msgstr "ຝາກແລ້ວ:"

#. module: pos_settle_due
#. odoo-javascript
#: code:addons/pos_settle_due/static/src/overrides/components/payment_screen/payment_screen.js:0
msgid "Do you want to deposit %s to %s?"
msgstr "ທ່ານຕ້ອງການຝາກ %s ໃຫ້ %s ບໍ່?"

#. module: pos_settle_due
#. odoo-javascript
#: code:addons/pos_settle_due/static/src/overrides/components/payment_screen/payment_screen.js:0
msgid ""
"Do you want to deposit %s to a specific customer? If so, first select "
"him/her."
msgstr ""
"ທ່ານຕ້ອງການຝາກ %s ໃຫ້ລູກຄ້າສະເພາະເຈາະຈົງບໍ່? ຖ້າແມ່ນ, ກະລຸນາເລືອກລູກຄ້າຜູ້ນັ້ນກ່ອນ."

#. module: pos_settle_due
#. odoo-javascript
#: code:addons/pos_settle_due/static/src/overrides/components/payment_screen/payment_screen.js:0
msgid "Empty Order"
msgstr "ລາຍການສັ່ງຊື້ຫວ່າງເປົ່າ"

#. module: pos_settle_due
#. odoo-javascript
#: code:addons/pos_settle_due/static/src/overrides/components/payment_screen/payment_screen.js:0
msgid "Empty orders cannot be invoiced."
msgstr "ລາຍການສັ່ງຊື້ຫວ່າງເປົ່າບໍ່ສາມາດອອກໃບແຈ້ງໜີ້ໄດ້."

#. module: pos_settle_due
#: model:ir.model,name:pos_settle_due.model_pos_session
