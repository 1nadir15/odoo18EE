msgid "Define Contact(s)"
msgstr "ກໍານົດຜູ້ຕິດຕໍ່"

#. module: account_saft
#: model:ir.model,name:account_saft.model_account_general_ledger_report_handler
msgid "General Ledger Custom Handler"
msgstr "ຕົວຈັດການບັນຊີແຍກປະເພດທົ່ວໄປແບບກຳນົດເອງ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "Missing company details."
msgstr "ຂໍ້ມູນລາຍລະອຽດຂອງບໍລິສັດບໍ່ຄົບຖ້ວນ."

#. module: account_saft
#: model_terms:ir.ui.view,arch_db:account_saft.saft_template
msgid "Odoo"
msgstr "Odoo"

#. module: account_saft
#: model_terms:ir.ui.view,arch_db:account_saft.saft_template
msgid "Odoo SA"
msgstr "Odoo SA"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "Partners to be checked"
msgstr "ຄູ່ຄ້າທີ່ຕ້ອງໄດ້ຮັບການກວດກາ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "Please define one or more Contacts belonging to your company."
msgstr ""
"ກະລຸນາກໍານົດຜູ້ຕິດຕໍ່ຢ່າງໜ້ອຍໜຶ່ງລາຍ ຫຼື ຫຼາຍກວ່ານັ້ນທີ່ຂຶ້ນກັບບໍລິສັດຂອງທ່ານ."

#. module: account_saft
#. odoo-javascript
#: code:addons/account_saft/static/src/components/general_ledger/filters/warnings.xml:0
msgid "Please define the following for"
msgstr "ກະລຸນາກໍານົດສິ່ງຕໍ່ໄປນີ້ໃຫ້ກັບ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "SAF-T is only compatible with one column group."
msgstr "SAF-T ແມ່ນສາມາດໃຊ້ງານໄດ້ກັບກຸ່ມຖັນດຽວເທົ່ານັ້ນ."

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "Some partners are missing at least one address (Zip/City)."
msgstr "ຄູ່ຄ້າບາງລາຍຍັງຂາດຂໍ້ມູນທີ່ຢູ່ຢ່າງໜ້ອຍໜຶ່ງຢ່າງ (ລະຫັດໄປສະນີ/ຕົວເມືອງ)."

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "View Company Partner"
msgstr "ເບິ່ງຄູ່ຄ້າຂອງບໍລິສັດ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "View Partners"
msgstr "ເບິ່ງຄູ່ຄ້າ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "the Company ID"
msgstr "ລະຫັດບໍລິສັດ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "the city or zip code"
msgstr "ຕົວເມືອງ ຫຼື ລະຫັດໄປສະນີ"

#. module: account_saft
#. odoo-python
#: code:addons/account_saft/models/account_general_ledger.py:0
msgid "the phone or mobile number"
msgstr "ເບີໂທລະສັບ ຫຼື ເບີມືຖື"

#. module: account_saft
#. odoo-javascript
#: code:addons/account_saft/static/src/components/general_ledger/filters/warnings.xml:0
msgid "your company"
msgstr "ບໍລິສັດຂອງທ່ານ"
