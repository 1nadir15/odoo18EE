#. module: snailmail_account_followup
#: model:ir.model,name:snailmail_account_followup.model_snailmail_letter_format_error
msgid "Format Error Sending a Snailmail Letter"
msgstr "ຮູບແບບຜິດພາດໃນການສົ່ງຈົດໝາຍທາງໄປສະນີ"

#. module: snailmail_account_followup
#. odoo-python
#: code:addons/snailmail_account_followup/wizard/snailmail_letter_format_error.py:0
msgid ""
"Payment reminders / follow-ups can not be updated and resent this way. They "
"have to be sent again in the same way as they were originally sent."
msgstr ""
"ການແຈ້ງເຕືອນການຊຳລະເງິນ / ການຕິດຕາມທວງຖາມ ບໍ່ສາມາດອັບເດດ ແລະ ສົ່ງຄືນໃໝ່ດ້ວຍວິທີນີ້ໄດ້. ພວກມັນຕ້ອ"
"ງໄດ້ຖືກສົ່ງຄືນໃໝ່ໃນຮູບແບບດຽວກັນກັບທີ່ເຄີຍສົ່ງໃນເບື້ອງຕົ້ນ."

#. module: snailmail_account_followup
