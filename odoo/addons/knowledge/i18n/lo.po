#. module: knowledge
#. odoo-javascript
#: code:addons/knowledge/static/src/components/knowledge_cover/knowledge_cover_dialog.js:0
msgid ""
"Are you sure you want to delete this cover? It will be removed from every "
"article it is used in."
msgstr ""
"ທ່ານແນ່ໃຈບໍວ່າຕ້ອງການລຶບຮູບໜ້າປົກນີ້? ມັນຈະຖືກລຶບອອກຈາກທຸກບົດຄວາມທີ່ໃຊ້ມັນຢູ່."

#. module: knowledge
#. odoo-javascript
#: code:addons/knowledge/static/src/components/permission_panel/permission_panel.js:0
msgid ""
"Are you sure you want to leave your private Article? As you are its last "
"member, it will be moved to the Trash."
msgstr ""
"ທ່ານແນ່ໃຈບໍວ່າຕ້ອງການອອກຈາກບົດຄວາມສ່ວນຕົວຂອງທ່ານ? ເນື່ອງຈາກທ່ານເປັນສະມາຊິກຄົນສຸດທ້າຍ, ມັນຈະຖືກຍ້າ"
"ຍໄປທີ່ຖັງຂີ້ເຫຍື້ອ."

#. module: knowledge
#. odoo-javascript
#: code:addons/knowledge/static/src/components/sidebar/sidebar.js:0
msgid ""
"Are you sure you want to move \"%(icon)s%(title)s\" to private? Only you "
"will be able to access it."
msgstr ""
"ທ່ານແນ່ໃຈບໍວ່າຕ້ອງການຍ້າຍ \"%(icon)s%(title)s\" ໄປທີ່ສ່ວນຕົວ? ມີພຽງແຕ່ທ່ານເທົ່ານັ້ນທີ່ຈະເຂົ້າເຖິງໄ"
"ດ້."

#. module: knowledge
#. odoo-javascript
#: code:addons/knowledge/static/src/components/sidebar/sidebar.js:0
msgid ""
"Are you sure you want to move \"%(icon)s%(title)s\" to the Shared section? "
"It will be shared with all listed members."
msgstr ""
"ທ່ານແນ່ໃຈບໍວ່າຕ້ອງການຍ້າຍ \"%(icon)s%(title)s\" ໄປທີ່ພາກສ່ວນແບ່ງປັນ? ມັນຈະຖືກແບ່ງປັນໃຫ້ກັບສະມາ"
"ຊິກທຸກຄົນທີ່ມີລາຍຊື່."

#. module: knowledge
#. odoo-javascript
#: code:addons/knowledge/static/src/components/sidebar/sidebar.js:0
msgid ""
"Are you sure you want to move \"%(icon)s%(title)s\" to the Workspace? It "
"will be shared with all internal users."
msgstr ""
"ທ່ານແນ່ໃຈບໍວ່າຕ້ອງການຍ້າຍ \"%(icon)s%(title)s\" ໄປທີ່ພື້ນທີ່ເຮັດວຽກ? ມັນຈະຖືກແບ່ງປັນໃຫ້ກັບຜູ້ໃຊ້ພາຍ"
"ໃນທຸກຄົນ."

#. module: knowledge
#. odoo-javascript
#: code:addons/knowledge/static/src/components/sidebar/sidebar.js:0
msgid ""
"Are you sure you want to move \"%(icon)s%(title)s\" under "
"\"%(parentIcon)s%(parentTitle)s\"? It will be shared with the same persons."
msgstr ""
"ທ່ານແນ່ໃຈບໍວ່າຕ້ອງການຍ້າຍ \"%(icon)s%(title)s\" ໄປໄວ້ກ້ອງ \"%(parentIcon)s%"
"(parentTitle)s\"? ມັນຈະຖືກແບ່ງປັນໃຫ້ກັບບຸກຄົນກຸ່ມດຽວກັນ."

#. module: knowledge
#. odoo-javascript
#: code:addons/knowledge/static/src/components/permission_panel/permission_panel.js:0
msgid ""
"Are you sure you want to remove your member? By leaving an article, you may "
"lose access to it."
msgstr ""
"ທ່ານແນ່ໃຈບໍວ່າຕ້ອງການລຶບສະມາຊິກຂອງທ່ານອອກ? ການອອກຈາກບົດຄວາມອາດເຮັດໃຫ້ທ່ານເສຍສິດການເຂົ້າເຖິງ."

#. module: knowledge
#. odoo-javascript
#: code:addons/knowledge/static/src/components/permission_panel/permission_panel.js:0
msgid "Are you sure you want to remove your own \"Write\" access?"
msgstr "ທ່ານແນ່ໃຈບໍວ່າຕ້ອງການລຶບສິດ \"ການຂຽນ\" ຂອງຕົວທ່ານເອງອອກ?"

#. module: knowledge
#. odoo-javascript
#: code:addons/knowledge/static/src/components/permission_panel/permission_panel.js:0
msgid ""
"Are you sure you want to restore access? This means this article will now "
"inherit any access set on its parent articles."
msgstr ""
