#. module: knowledge
#. odoo-python
#: code:addons/knowledge/models/knowledge_article.py:0
msgid ""
"\"%(article_item_name)s\" is an Article Item from \"%(article_name)s\" and "
"cannot be restored on its own. Contact the owner of \"%(article_name)s\" to "
"have it restored instead."
msgstr ""
"\"%(article_item_name)s\" ແມ່ນລາຍການບົດຄວາມຈາກ \"%(article_name)s\" ແລະ ບໍ່ສາມາດກູ້"
"ຄືນດ້ວຍຕົວມັນເອງໄດ້. ກະລຸນາຕິດຕໍ່ເຈົ້າຂອງ \"%(article_name)s\" ເພື່ອກູ້ຄືນແທນ."

#. module: knowledge
#. odoo-python
#: code:addons/knowledge/models/knowledge_article.py:0
msgid ""
"\"%(article_name)s\" is a template and can not be a child of an article "
"(\"%(parent_article_name)s\")."
msgstr ""
"\"%(article_name)s\" ແມ່ນແມ່ແບບ ແລະ ບໍ່ສາມາດເປັນລູກຂອງບົດຄວາມ (\"%"
"(parent_article_name)s\")."

#. module: knowledge
#. odoo-python
#: code:addons/knowledge/models/knowledge_article.py:0
msgid ""
"\"%(article_name)s\" is an article and can not be a child of a template "
"(\"%(parent_article_name)s\").\""
msgstr ""
"\"%(article_name)s\" ແມ່ນບົດຄວາມ ແລະ ບໍ່ສາມາດເປັນລູກຂອງແມ່ແບບ (\"%"
"(parent_article_name)s\").\""

