#. module: documents
#. odoo-python
#: code:addons/documents/models/documents_document.py:0
msgid "You are not allowed to (un)archive documents."
msgstr "ທ່ານບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ເກັບ/ຖອນການເກັບ ເອກະສານ."

#. module: documents
#. odoo-python
#: code:addons/documents/models/documents_document.py:0
msgid "You are not allowed to change ownerships of documents you do not own."
msgstr "ທ່ານບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ປ່ຽນເຈົ້າຂອງເອກະສານທີ່ທ່ານບໍ່ໄດ້ເປັນເຈົ້າຂອງ."

#. module: documents
#. odoo-python
#: code:addons/documents/models/documents_document.py:0
msgid "You are not allowed to execute embedded actions."
msgstr "ທ່ານບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ປະຕິບັດການດຳເນີນການທີ່ຝັງໄວ້."

#. module: documents
#. odoo-python
#: code:addons/documents/models/documents_document.py:0
msgid "You are not allowed to move (some of) these documents."
msgstr "ທ່ານບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ຍ້າຍເອກະສານເຫຼົ່ານີ້ (ບາງສ່ວນ)."

#. module: documents
#. odoo-python
#: code:addons/documents/models/documents_document.py:0
msgid "You are not allowed to pin/unpin embedded Actions."
msgstr "ທ່ານບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ປັກໝຸດ/ຖອນການປັກໝຸດ ການດຳເນີນການທີ່ຝັງໄວ້."

#. module: documents
#. odoo-python
#: code:addons/documents/models/documents_document.py:0
msgid "You are not allowed to read the permission panel data."
msgstr "ທ່ານບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ອ່ານຂໍ້ມູນໃນແຖບການກຳນົດສິດ."

#. module: documents
#. odoo-python
#: code:addons/documents/models/documents_document.py:0
msgid "You are not allowed to write in this folder."
msgstr "ທ່ານບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ຂຽນ (ສ້າງ/ແກ້ໄຂ) ໃນໂຟນເດີນີ້."

#. module: documents
#: model:ir.model.fields,help:documents.field_documents_document__attachment_type
msgid ""
"You can either upload a file from your computer or copy/paste an internet "
"link to your file."
msgstr "ທ່ານສາມາດອັບໂຫຼດໄຟລ໌ຈາກຄອມພິວເຕີຂອງທ່ານ ຫຼື ຄັດລອກ/ວາງລິງກ໌ອິນເຕີເນັດຫາໄຟລ໌ຂອງທ່ານໄດ້."

#. module: documents
#. odoo-javascript
#: code:addons/documents/static/src/views/cog_menu/documents_cog_menu_pin_actions.js:0
msgid "You can not pin actions for that folder."
msgstr "ທ່ານບໍ່ສາມາດປັກໝຸດການດຳເນີນການສຳລັບໂຟນເດີນັ້ນໄດ້."

#. module: documents
#. odoo-python
#: code:addons/documents/models/documents_document.py:0
