msgid "You cannot assign yourself to a shift in the past."
msgstr "Du kan ikke tildele dig selv en vagt i fortiden."

#. module: planning
#. odoo-python
#: code:addons/planning/models/planning.py:0
msgid "You cannot cancel a request to switch made by another user."
msgstr ""
"Du kan ikke annullere en bytteanmodning, som er oprettet af en anden bruger."

#. module: planning
#. odoo-python
#: code:addons/planning/models/planning.py:0
msgid "You cannot cancel a request to switch that is in the past."
msgstr "Du kan ikke annullere en bytteanmodning, der ligger i fortiden."

#. module: planning
#. odoo-python
#: code:addons/planning/models/planning.py:0
msgid "You cannot request to switch a shift that is assigned to another user."
msgstr "Du kan ikke anmode om at bytte en vagt, der er tildelt en anden bruger."

#. module: planning
#. odoo-python
#: code:addons/planning/models/planning.py:0
msgid "You cannot switch a shift that is in the past."
msgstr "Du kan ikke bytte en vagt, der allerede har fundet sted."

#. module: planning
#. odoo-python
#: code:addons/planning/models/planning.py:0
msgid "You cannot unassign yourself from a shift in the past."
msgstr "Du kan ikke afmelde dig selv fra en vagt i fortiden."

#. module: planning
#. odoo-javascript
#: code:addons/planning/static/src/js/planning_calendar_front.js:0
msgid "You don't have any shifts planned yet."
msgstr "Der er endnu ikke planlagt nogen vagter."

#. module: planning
#. odoo-javascript
#: code:addons/planning/static/src/js/planning_calendar_front.js:0
msgid ""
"You don't have any shifts planned yet. You can assign yourself some of the "
"available open shifts."
msgstr ""
"Du har endnu ikke planlagt nogen vagter. Du kan selv tage nogle af de ledige "
"vagter."

#. module: planning
#. odoo-python
#: code:addons/planning/models/planning.py:0
msgid "You don't have the right to assign yourself to shifts."
msgstr "Du har ikke tilladelse til at tildele dig selv vagter."

#. module: planning
#. odoo-python
#: code:addons/planning/models/planning.py:0
msgid "You don't have the right to cancel a request to switch."
msgstr "Du har ikke tilladelse til at annullere en bytteanmodning."

#. module: planning
#. odoo-python
#: code:addons/planning/models/planning.py:0
msgid "You don't have the right to switch shifts."
msgstr "Du har ikke tilladelse til at bytte vagter."

